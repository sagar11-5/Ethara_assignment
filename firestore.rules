rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Rules
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.email == request.auth.token.email;
      allow create: if isOwner(userId) && 
        request.resource.data.keys().hasAll(['uid', 'name', 'email', 'createdAt']) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.name is string &&
        request.resource.data.email == request.auth.token.email;
      allow update: if isOwner(userId) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'avatarUrl']);
    }

    // Project Rules
    match /projects/{projectId} {
      function isProjectMember(projectData) {
        return isSignedIn() && request.auth.uid in projectData.memberIds;
      }

      allow get: if isSignedIn() && isProjectMember(resource.data);
      allow list: if isSignedIn() && request.auth.uid in resource.data.memberIds;
      
      allow create: if isSignedIn() && 
        request.resource.data.adminId == request.auth.uid &&
        request.auth.uid in request.resource.data.memberIds &&
        request.resource.data.name is string && request.resource.data.name.size() > 0 &&
        request.resource.data.memberIds is list && request.resource.data.memberIds.size() > 0;

      allow update: if isSignedIn() && (
        // Admin update (everything except immutable fields maybe, but let's keep it simple)
        (resource.data.adminId == request.auth.uid && request.resource.data.adminId == resource.data.adminId) ||
        // Member update (only if they are in memberIds, rarely needed for project doc itself)
        (request.auth.uid in resource.data.memberIds && request.resource.data.diff(resource.data).affectedKeys().hasOnly([]))
      );

      allow delete: if isSignedIn() && resource.data.adminId == request.auth.uid;

      // Task Rules (Subcollection)
      match /tasks/{taskId} {
        function isParentProjectMember() {
          return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.memberIds;
        }

        allow read: if isParentProjectMember();
        
        allow create: if isParentProjectMember() &&
          request.resource.data.projectId == projectId &&
          request.resource.data.creatorId == request.auth.uid &&
          request.resource.data.status in ['To Do', 'In Progress', 'Done'];

        allow update: if isParentProjectMember() && (
          // Admin or Creator can update anything
          (request.auth.uid == resource.data.creatorId || get(/databases/$(database)/documents/projects/$(projectId)).data.adminId == request.auth.uid) ||
          // Assignee can only update status
          (request.auth.uid == resource.data.assigneeId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
        );

        allow delete: if isParentProjectMember() && (
          request.auth.uid == resource.data.creatorId || 
          get(/databases/$(database)/documents/projects/$(projectId)).data.adminId == request.auth.uid
        );
      }
    }
  }
}
